add_action('template_redirect', static function () {
    if (!function_exists('is_page') || !is_page('suspended')) {
        return;
    }

    if (!class_exists('Printonet_Tenant_Control') || !Printonet_Tenant_Control::is_suspended()) {
        wp_safe_redirect(home_url('/'));
        exit;
    }

    status_header(503);
    nocache_headers();
});

/**
 * Shared product query for homepage rails.
 *
 * @return array<int,WC_Product>
 */
function printonet_theme_get_products(int $limit = 6): array
{
    if (!function_exists('wc_get_products')) {
        return [];
    }

    return wc_get_products([
        'status' => 'publish',
        'limit' => $limit,
        'orderby' => 'date',
        'order' => 'DESC',
        'return' => 'objects',
    ]);
}

