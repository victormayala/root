<?php

if (!defined('ABSPATH')) {
    exit;
}

class Printonet_Provisioning_API
{
    public static function init(): void
    {
        add_action('rest_api_init', [self::class, 'register_routes']);
    }

    public static function register_routes(): void
    {
        register_rest_route('printonet/v1', '/provision-store', [
            'methods' => 'POST',
            'callback' => [self::class, 'provision_store'],
            'permission_callback' => [self::class, 'authenticate'],
        ]);
    }

    public static function authenticate(WP_REST_Request $request): bool
    {
        // Prefer signed requests from the main Printonet platform.
        if (Printonet_Request_Auth::verify_platform_signature($request)) {
            return true;
        }

        // Fallback API key for transitional rollout.
        $incoming = (string) $request->get_header('x-printonet-api-key');
        $expected = defined('PRINTONET_PROVISIONING_API_KEY')
            ? (string) PRINTONET_PROVISIONING_API_KEY
            : (string) getenv('PROVISIONING_API_KEY');

        if ($incoming === '' || $expected === '') {
            return false;
        }

        return hash_equals($expected, $incoming);
    }

    public static function provision_store(WP_REST_Request $request): WP_REST_Response
    {
        $payload = $request->get_json_params();
        $required = ['tenant_slug', 'store_name', 'admin_email'];

        foreach ($required as $field) {
            if (empty($payload[$field])) {
                return new WP_REST_Response([
                    'success' => false,
                    'error' => "Missing required field: {$field}",
                ], 422);
            }
        }

        $tenant_slug = sanitize_title($payload['tenant_slug']);
        $domain = $tenant_slug . '.' . preg_replace('#^https?://#', '', network_home_url());
        $domain = preg_replace('#/.*$#', '', $domain);

        if (domain_exists($domain, '/', get_current_network_id())) {
            return new WP_REST_Response([
                'success' => false,
                'error' => 'Tenant already exists',
            ], 409);
        }

        $site_id = wpmu_create_blog(
            $domain,
            '/',
            sanitize_text_field($payload['store_name']),
            1,
            [],
            get_current_network_id()
        );

        if (is_wp_error($site_id)) {
            return new WP_REST_Response([
                'success' => false,
                'error' => $site_id->get_error_message(),
            ], 500);
        }

        $admin_user_id = self::ensure_tenant_admin((int) $site_id, $payload);

        switch_to_blog((int) $site_id);
        update_option('blogname', sanitize_text_field($payload['store_name']));
        update_option('printonet_brand_primary_color', sanitize_hex_color($payload['primary_color'] ?? '#111111'));
        update_option('printonet_brand_secondary_color', sanitize_hex_color($payload['secondary_color'] ?? '#ffffff'));
        update_option('printonet_logo_url', esc_url_raw($payload['logo_url'] ?? ''));
        self::apply_default_woo_settings($payload);

        // Ensure shared theme is active for each tenant store.
        switch_theme('printonet-storefront');
        restore_current_blog();

        return new WP_REST_Response([
            'success' => true,
            'site_id' => $site_id,
            'admin_user_id' => $admin_user_id,
            'store_url' => 'https://' . $domain,
        ], 201);
    }

    private static function ensure_tenant_admin(int $site_id, array $payload): int
    {
        $email = sanitize_email((string) $payload['admin_email']);
        $username = !empty($payload['admin_username'])
            ? sanitize_user((string) $payload['admin_username'], true)
            : sanitize_user(str_replace('@', '_', $email), true);
        $password = !empty($payload['admin_password'])
            ? (string) $payload['admin_password']
            : wp_generate_password(20, true, true);

        if (!is_email($email)) {
            return 1;
        }

        $user = get_user_by('email', $email);
        if (!$user) {
            $user_id = wp_create_user($username, $password, $email);
            if (is_wp_error($user_id)) {
                $fallback_username = sanitize_user($username . '_' . wp_generate_password(4, false, false), true);
                $user_id = wp_create_user($fallback_username, $password, $email);
                if (is_wp_error($user_id)) {
                    return 1;
                }
            }
        } else {
            $user_id = (int) $user->ID;
        }

        add_user_to_blog($site_id, $user_id, 'administrator');
        return (int) $user_id;
    }

    private static function apply_default_woo_settings(array $payload): void
    {
        update_option('woocommerce_currency', sanitize_text_field($payload['currency'] ?? 'USD'));
        update_option('woocommerce_default_country', sanitize_text_field($payload['default_country'] ?? 'US:CA'));
        update_option('woocommerce_weight_unit', sanitize_text_field($payload['weight_unit'] ?? 'lbs'));
        update_option('woocommerce_dimension_unit', sanitize_text_field($payload['dimension_unit'] ?? 'in'));

        // Start with lightweight checkout while preserving store flexibility.
        update_option('woocommerce_enable_guest_checkout', 'yes');
        update_option('woocommerce_enable_signup_and_login_from_checkout', 'yes');
    }
}
