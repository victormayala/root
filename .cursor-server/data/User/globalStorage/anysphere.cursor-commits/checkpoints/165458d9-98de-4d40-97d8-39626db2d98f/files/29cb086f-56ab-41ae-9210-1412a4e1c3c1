add_action('wp', static function () {
    if (!function_exists('is_shop')) {
        return;
    }

    if (is_shop() || is_product_taxonomy()) {
        remove_action('storefront_sidebar', 'storefront_get_sidebar', 10);
    }
});

add_filter('body_class', static function (array $classes): array {
    if (!function_exists('is_shop')) {
        return $classes;
    }

    if (is_shop() || is_product_taxonomy()) {
        $classes = array_values(array_diff($classes, ['right-sidebar', 'left-sidebar']));
        if (!in_array('storefront-full-width-content', $classes, true)) {
            $classes[] = 'storefront-full-width-content';
        }
    }

    return $classes;
});


add_filter('loop_shop_columns', static function (int $columns): int {
    unset($columns);
    return 5;
}, 20);

add_filter('loop_shop_per_page', static function (int $per_page): int {
    unset($per_page);
    return 20;
}, 20);

function printonet_theme_banner_placeholder(string $slot): string
{
    $map = [
        'hero' => 'hero.jpg',
        'intro' => 'one.jpg',
        'story' => 'two.jpg',
    ];

    $filename = $map[$slot] ?? 'hero.jpg';
    return get_stylesheet_directory_uri() . '/assets/placeholders/' . $filename;
}

