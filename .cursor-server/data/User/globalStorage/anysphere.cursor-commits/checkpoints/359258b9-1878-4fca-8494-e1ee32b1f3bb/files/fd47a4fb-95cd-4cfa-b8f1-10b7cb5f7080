Theme Name: Printonet Theme
Theme URI: https://printonet.example
Author: Printonet
Description: Editorial outdoor-inspired WooCommerce storefront for Printonet stores.
Version: 0.1.0
Template: storefront
Text Domain: printonet-theme
*/

:root {
  --printonet-primary: #111111;
  --printonet-secondary: #ffffff;
  --printonet-surface: #f6f4ec;
  --printonet-text: #171717;
  --printonet-radius: 0;
  --printonet-gap: clamp(0.8rem, 1.5vw, 1.25rem);
}

body {
  color: var(--printonet-text);
  background: #fff;
}

.site-main {
  margin-top: 0;
}

.printonet-home {
  display: grid;
  gap: 1.2rem;
}

.printonet-section {
  width: min(1440px, calc(100% - 2rem));
  margin: 0 auto;
}

.printonet-hero {
  position: relative;
  min-height: clamp(360px, 55vw, 620px);
  border-radius: var(--printonet-radius);
  overflow: hidden;
  display: grid;
  align-items: end;
  padding: clamp(1rem, 4vw, 3rem);
  color: #fff;
  isolation: isolate;
  background: #222;
}

.printonet-hero__media {
  position: absolute;
  inset: 0;
  z-index: -2;
}

.printonet-hero__media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.printonet-hero::after {
  content: "";
  position: absolute;
  inset: 0;
  z-index: -1;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.1) 0%, rgba(0, 0, 0, 0.65) 100%);
}

.printonet-pill {
  display: inline-flex;
  justify-self: start;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.72rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.35rem 0.6rem;
  background: rgba(255, 255, 255, 0.16);
  border: 1px solid rgba(255, 255, 255, 0.25);
}

.printonet-hero h1 {
  margin: 0.8rem 0 0.4rem;
  color: inherit;
  font-size: clamp(2rem, 5vw, 4rem);
  line-height: 0.98;
}

.printonet-hero p {
  margin: 0;
  max-width: 42ch;
}

.printonet-btn {
  display: inline-block;
  justify-self: start;
  margin-top: 1rem;
  border: 1px solid #fff;
  color: #fff;
  padding: 0.6rem 1rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-size: 0.72rem;
}

.printonet-btn:hover {
  background: #fff;
  color: #111;
}

.printonet-grid {
  display: grid;
  gap: var(--printonet-gap);
}

.printonet-grid--five {
  grid-template-columns: repeat(5, minmax(0, 1fr));
}

.printonet-grid--three {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.printonet-card {
  position: relative;
  overflow: hidden;
  background: #efefef;
}

.printonet-card img {
  width: 100%;
  aspect-ratio: 5 / 4;
  object-fit: cover;
  display: block;
}

.printonet-card__meta {
  padding: 0.65rem 0.2rem 0;
}

.printonet-card__title {
  display: block;
  color: #111;
  font-weight: 700;
  line-height: 1.25;
  margin-bottom: 0.2rem;
}

.printonet-card__price,
.printonet-card__sub {
  color: #555;
  font-size: 0.8rem;
}

.printonet-feature-split {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  min-height: 360px;
}

.printonet-feature-split__media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.printonet-feature-split__body {
  background: var(--printonet-surface);
  align-items: start;
  padding: clamp(1.3rem, 3vw, 2.4rem);
  display: grid;
  align-content: center;
  gap: 0.65rem;
}

.printonet-feature-split__body h2 {
  margin: 0;
  font-size: clamp(1.5rem, 3vw, 2.6rem);
  line-height: 1.05;
}

.printonet-feature-split__body p {
  margin: 0;
}

.printonet-footer-band {
  background: #0a0a0a;
  color: #f2f2f2;
  margin-top: 1.5rem;
  padding: 1.8rem 0;
}

.printonet-footer-band .printonet-section {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 1.2rem;
}

.printonet-footer-band h3 {
  margin: 0 0 0.55rem;
  color: #fff;
  font-size: 1rem;
}

.printonet-footer-band p {
  margin: 0;
  font-size: 0.9rem;
  color: #d7d7d7;
}

.home.blog .site-content > .col-full > .site-main > article,
.home.blog .site-content > .col-full > .site-main > .woocommerce,
.home.blog .site-content > .col-full > .site-main > .wp-block-group {
  display: none;
}

@media (max-width: 1080px) {
  .printonet-grid--five {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .printonet-feature-split,
  .printonet-footer-band .printonet-section {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 720px) {
  .printonet-grid--five,
  .printonet-grid--three {
    grid-template-columns: 1fr 1fr;
  }

  .printonet-section {
    width: min(1440px, calc(100% - 1rem));
  }
}

.col-full,
.site-content .col-full,
.site-header .col-full,
.site-footer .col-full {
  max-width: 1440px;
  width: min(1440px, calc(100% - 2rem));
  margin-left: auto;
  margin-right: auto;
}

@media (max-width: 720px) {
  .col-full,
  .site-content .col-full,
  .site-header .col-full,
  .site-footer .col-full {
    width: min(1440px, calc(100% - 1rem));
  }
}


.printonet-card--product {
  background: #f3f3f3;
}

.printonet-card--product img {
  object-fit: contain;
  background: #f3f3f3;
  padding: 0.75rem;
}


.printonet-card--product a {
  display: block;
  background: #f3f3f3;
}

.printonet-card--product img {
  height: clamp(220px, 26vw, 320px);
}




.printonet-feature-split--intro {
  min-height: 480px;
  height: 480px;
  grid-template-rows: 480px;
}

.printonet-feature-split--intro .printonet-feature-split__media,
.printonet-feature-split--intro .printonet-feature-split__body {
  height: 480px;
}

.printonet-feature-split--intro .printonet-feature-split__media img {
  height: 100%;
  object-fit: cover;
}


.printonet-feature-split--story {
  min-height: 480px;
  height: 480px;
  grid-template-rows: 480px;
}

.printonet-feature-split--story .printonet-feature-split__media,
.printonet-feature-split--story .printonet-feature-split__body {
  height: 480px;
}

.printonet-feature-split--story .printonet-feature-split__media img {
  height: 100%;
  object-fit: cover;
}
