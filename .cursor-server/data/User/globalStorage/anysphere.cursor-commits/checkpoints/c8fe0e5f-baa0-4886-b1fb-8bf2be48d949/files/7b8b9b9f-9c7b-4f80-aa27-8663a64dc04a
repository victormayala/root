<?php

if (!defined('ABSPATH')) {
    exit;
}

get_header();

$products = printonet_theme_get_products(30);
$product_categories = get_terms([
    'taxonomy' => 'product_cat',
    'hide_empty' => true,
    'number' => 6,
]);
if (is_wp_error($product_categories)) {
    $product_categories = [];
}

$latest_posts = get_posts([
    'post_type' => 'post',
    'post_status' => 'publish',
    'numberposts' => 3,
]);

$hero_cta_url = function_exists('wc_get_page_permalink') ? wc_get_page_permalink('shop') : home_url('/shop');
$hero_image = printonet_theme_banner_placeholder('hero');
$promo_one_image = printonet_theme_banner_placeholder('intro');
$promo_two_image = printonet_theme_banner_placeholder('story');

$featured_products = array_slice($products, 0, min(10, count($products)));
$deal_products = array_slice($products, 10, 4);
if (count($deal_products) < 4) {
    $deal_products = array_slice($products, 0, min(4, count($products)));
}
$bestsellers = array_slice($products, 14, 10);
if (count($bestsellers) < 10) {
    $bestsellers = array_slice($products, 0, min(10, count($products)));
}

$render_product_card = static function ($product, int $index = 0): void {
    if (!$product) {
        return;
    }
    $image = $product->get_image_id()
        ? wp_get_attachment_image_url($product->get_image_id(), 'medium_large')
        : printonet_theme_placeholder_image('product-' . $index);
    ?>
    <article class="printonet-pets-card">
      <a class="printonet-pets-card__media" href="<?php echo esc_url(get_permalink($product->get_id())); ?>">
        <span class="printonet-pets-card__badge">Top pick</span>
        <img src="<?php echo esc_url($image); ?>" alt="<?php echo esc_attr($product->get_name()); ?>">
      </a>
      <div class="printonet-pets-card__meta">
        <a class="printonet-pets-card__title" href="<?php echo esc_url(get_permalink($product->get_id())); ?>"><?php echo esc_html($product->get_name()); ?></a>
        <div class="printonet-pets-card__price"><?php echo wp_kses_post($product->get_price_html()); ?></div>
      </div>
    </article>
    <?php
};
?>

